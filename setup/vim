#!/usr/bin/env bash
# =============================================================================
# Creates:  ~/.vimrc -> dotfiles/.vimrc
# Installs: vim-plug
# Usage: bash setup/vim [/path/to/dotfiles/repo]
# Idempotent: Safe to rerun.
# =============================================================================

set -e

LOGGER_SCRIPT_NAME="git setup"

SETUP_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SETUP_DIR}/utils"

DOTFILES="${1:-$(dirname "$SETUP_DIR")}"

# --- Symlink -----------------------------------------------------------------

make_symlink  "${DOTFILES}/vimrc" "${HOME}/.vimrc"   

# --- vim-plug ----------------------------------------------------------------

PLUG_PATH="${HOME}/.vim/autoload/plug.vim"

if [[ -f "$PLUG_PATH" ]]; then
    log "vim-plug already installed"
else
    log "Installing vim-plug..."
    curl -fLo "$PLUG_PATH" --create-dirs \
        https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
    log "Done. Open vim and run :PlugInstall to install plugins."
fi